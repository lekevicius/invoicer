{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/seller.schema.json",
  "title": "SellerInput",
  "type": "object",
  "additionalProperties": false,
  "required": ["seller"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "seller": {
      "type": "object",
      "additionalProperties": false,
      "required": ["details", "bank_details"],
      "properties": {
        "details": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/detailBlock"
          }
        },
        "bank_details": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/bankDetailRow"
          }
        },
        "assets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "background": {
              "$ref": "#/definitions/optionalAssetPath"
            },
            "logotype": {
              "$ref": "#/definitions/optionalAssetPath"
            },
            "signature": {
              "type": ["object", "null"],
              "additionalProperties": false,
              "required": ["svg"],
              "properties": {
                "svg": {
                  "$ref": "#/definitions/optionalAssetPath"
                },
                "x": {
                  "type": "number"
                },
                "y": {
                  "type": "number"
                },
                "width": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              }
            }
          }
        },
        "theme": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "colors": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "background": {
                  "$ref": "#/definitions/hexColor"
                },
                "heading": {
                  "$ref": "#/definitions/hexColor"
                },
                "text": {
                  "$ref": "#/definitions/hexColor"
                },
                "border": {
                  "$ref": "#/definitions/hexColor"
                }
              }
            },
            "font": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "family": {
                  "type": "string",
                  "minLength": 1
                },
                "paths": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/assetPath"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "detailBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "lines"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "lines": {
          "$ref": "#/definitions/nonEmptyStringArray"
        },
        "first_weight": {
          "enum": ["regular", "semibold"]
        }
      }
    },
    "bankDetailRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "value"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "optionalAssetPath": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "assetPath": {
      "type": "string",
      "minLength": 1
    },
    "hexColor": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    }
  }
}
