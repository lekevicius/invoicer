{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/invoice.schema.json",
  "title": "InvoiceInput",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "invoice", "buyer", "items"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "locale"],
      "properties": {
        "schema": {
          "const": 1
        },
        "locale": {
          "enum": ["en-US", "lt-LT"]
        }
      }
    },
    "invoice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number", "issue_date", "due_date", "currency", "project"],
      "properties": {
        "number": {
          "type": "string",
          "minLength": 1
        },
        "issue_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "due_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "project": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "buyer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "company_code", "address"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "company_code": {
          "type": "string",
          "minLength": 1
        },
        "address": {
          "$ref": "#/definitions/nonEmptyStringArray"
        }
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "amount"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "amount": {
            "type": "number"
          }
        }
      }
    }
  },
  "definitions": {
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
